generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DayPlan {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD format
  blocks    Block[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Block {
  id              String      @id @default(cuid())
  dayPlanId       String
  dayPlan         DayPlan     @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  type            String      // LESSON, EVENT, BREAK
  title           String
  durationMinutes Int
  startTime       String?     // HH:MM optional
  status          String      @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, DONE, SKIPPED
  orderIndex      Int
  notes           String?
  color           String      @default("#3b82f6")
  segments        Segment[]
  subtasks        Subtask[]
  timerState      TimerState?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([dayPlanId])
}

model Segment {
  id              String @id @default(cuid())
  blockId         String
  block           Block  @relation(fields: [blockId], references: [id], onDelete: Cascade)
  title           String
  durationMinutes Int
  status          String @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, DONE
  orderIndex      Int

  @@index([blockId])
}

model Subtask {
  id         String  @id @default(cuid())
  blockId    String
  block      Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  title      String
  isDone     Boolean @default(false)
  orderIndex Int

  @@index([blockId])
}

model TimerState {
  id               String    @id @default(cuid())
  blockId          String    @unique
  block            Block     @relation(fields: [blockId], references: [id], onDelete: Cascade)
  segmentIndex     Int?
  startedAt        DateTime?
  remainingSeconds Int
  isRunning        Boolean   @default(false)
}

// ============================================
// Mind Learning System Models
// ============================================

// Subject (Предмет обучения)
model Subject {
  id              String          @id @default(cuid())
  name            String          // "A Level Physics"
  emoji           String          @default("📚")
  color           String          @default("#8b5cf6")
  targetHoursWeek Float           @default(5)
  textbookUrl     String?
  topics          Topic[]
  scheduledTests  ScheduledTest[]
  reviewSets      ReviewSet[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// Topic (Тема для изучения)
model Topic {
  id             String          @id @default(cuid())
  subjectId      String
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name           String
  status         String          @default("NOT_STARTED") // NOT_STARTED, MEDIUM, SUCCESS, MASTERED
  studyState     String          @default("NOT_STUDIED") // STUDIED, NOT_STUDIED
  picked         Boolean         @default(false)
  orderIndex     Int             @default(0) // Order within subject for program planning
  archived       Boolean         @default(false)
  lastRevisedAt  DateTime?
  nextReviewAt   DateTime?
  intervalDays   Int?
  easeFactor     Float           @default(2.5)
  reviewLogs     ReviewLog[]
  studySessions  MindSession[]
  topicPlans     TopicPlan[]
  subtopics      Subtopic[]
  reviewSets     ReviewSet[]
  reviewSetLinks ReviewSetLink[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([subjectId])
}

// ReviewLog (Лог повторений)
model ReviewLog {
  id                String   @id @default(cuid())
  topicId           String
  topic             Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  rating            String   // AGAIN, HARD, GOOD, EASY
  reviewedAt        DateTime @default(now())
  intervalDaysAfter Int

  @@index([topicId])
}

// MindSession (Сессия учёбы для Mind)
model MindSession {
  id            String    @id @default(cuid())
  taskName      String
  topicId       String?
  topic         Topic?    @relation(fields: [topicId], references: [id], onDelete: SetNull)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  breaksMinutes Int       @default(0)
  totalMinutes  Int?

  @@index([topicId])
}

// User context for AI memory
model UserContext {
  id              String   @id @default(cuid())
  key             String   @unique  // e.g. "preferences", "goals", "learning_style"
  value           String   // JSON string with context data
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// AI conversation memory
model AIMemory {
  id        String   @id @default(cuid())
  type      String   // "fact", "preference", "goal", "observation"
  content   String   // What the AI learned about the user
  importance Int     @default(1) // 1-5 importance score
  createdAt DateTime @default(now())
}

// Cache for AI responses to minimize API calls
model AICache {
  id        String   @id @default(cuid())
  key       String   @unique // "daily_tasks", "analysis", "schedule"
  response  String   // JSON response from AI
  expiresAt DateTime // When this cache entry should be refreshed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Schedule blocks for the weekly planner
model ScheduleBlock {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0 = Monday, 6 = Sunday
  startTime   String   // "09:00"
  endTime     String   // "10:30"
  task        String   // Block title
  color       String   @default("#3b82f6")
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  subjectEmoji String?
  subjectName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI-generated learning program
model LearningProgram {
  id              String      @id @default(cuid())
  name            String      @default("Моя программа обучения")
  startDate       DateTime    @default(now())
  endDate         DateTime?   // Goal deadline
  totalWeeks      Int         @default(12)
  hoursPerWeek    Int         @default(20)
  isActive        Boolean     @default(true)
  generatedAt     DateTime    @default(now())
  
  // AI-generated summary
  description     String?
  strategy        String?     // JSON: AI's learning strategy

  weekPlans       WeekPlan[]
  topicPlans      TopicPlan[]
  scheduledTests  ScheduledTest[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Weekly breakdown of the program
model WeekPlan {
  id            String          @id @default(cuid())
  programId     String
  program       LearningProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  weekNumber    Int
  startDate     DateTime
  endDate       DateTime
  
  // Hours allocated per subject (JSON: { subjectId: hours })
  subjectHours  String          @default("{}")
  
  // AI notes for this week
  focus         String?
  notes         String?
  
  @@unique([programId, weekNumber])
  @@index([programId])
}

// Individual topic study plan
model TopicPlan {
  id              String          @id @default(cuid())
  programId       String
  program         LearningProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  topicId         String
  topic           Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  plannedWeek     Int             // Which week to study
  estimatedHours  Float           // AI-estimated hours needed
  priority        Int             @default(1) // 1-5, higher = more important
  
  // Deadline and flexibility
  deadline        DateTime?       // Hard deadline for this topic
  isFlexible      Boolean         @default(true) // Can be moved by auto-rebalance?
  manuallyMoved   Boolean         @default(false) // User explicitly moved this topic
  
  // Reinforcement schedule
  reinforceWeek1  Int?            // First review week
  reinforceWeek2  Int?            // Second review week
  
  // Status
  status          String          @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  completedAt     DateTime?
  
  @@index([programId])
  @@index([topicId])
}

// Scheduled tests
model ScheduledTest {
  id          String          @id @default(cuid())
  programId   String
  program     LearningProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  scheduledDate DateTime
  scheduledTime String?       // "HH:MM" format
  
  // What topics are covered
  topicsCovered String        // JSON array of topic IDs
  
  // Test details
  title         String
  description   String?
  type          String        @default("TOPIC_TEST") // TOPIC_TEST, MODULE_TEST, FINAL_TEST
  
  // Status
  status        String        @default("SCHEDULED") // SCHEDULED, COMPLETED, SKIPPED
  completedAt   DateTime?
  score         Float?        // 0-100 if completed
  
  @@index([programId])
  @@index([subjectId])
}

// ============================================
// Subtopics & Spaced Repetition System
// ============================================

// Subtopic under a Topic
model Subtopic {
  id         String    @id @default(cuid())
  topicId    String
  topic      Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title      String
  orderIndex Int       @default(0)
  srsState   SrsState?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([topicId])
}

// Polymorphic SRS state for Subtopics and ReviewSets
model SrsState {
  id             String     @id @default(cuid())
  entityType     String     // "SUBTOPIC" | "REVIEW_SET"
  subtopicId     String?    @unique
  subtopic       Subtopic?  @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  reviewSetId    String?    @unique
  reviewSet      ReviewSet? @relation(fields: [reviewSetId], references: [id], onDelete: Cascade)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  intervalDays   Int?
  easeFactor     Float      @default(2.5)
  mastery        Int        @default(0) // 0-100
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// End-of-chapter or cross-topic review sets
model ReviewSet {
  id         String          @id @default(cuid())
  subjectId  String?
  subject    Subject?        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topicId    String?
  topic      Topic?          @relation(fields: [topicId], references: [id], onDelete: SetNull)
  title      String
  type       String          // "END_OF_CHAPTER" | "CROSS_TOPIC"
  orderIndex Int             @default(0)
  srsState   SrsState?
  links      ReviewSetLink[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([subjectId])
  @@index([topicId])
}

// Links ReviewSet to multiple Topics (for cross-topic)
model ReviewSetLink {
  id          String    @id @default(cuid())
  reviewSetId String
  reviewSet   ReviewSet @relation(fields: [reviewSetId], references: [id], onDelete: Cascade)
  topicId     String
  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([reviewSetId, topicId])
}

// SRS Review Log (updated for polymorphic entities)
model SrsReviewLog {
  id                String   @id @default(cuid())
  entityType        String   // "SUBTOPIC" | "REVIEW_SET"
  entityId          String
  rating            String   // AGAIN, HARD, GOOD, EASY
  reviewedAt        DateTime @default(now())
  intervalDaysAfter Int

  @@index([entityId])
}
